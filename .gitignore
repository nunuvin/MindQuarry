!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/mindquarry/coverage

# next.js
/mindquarry/.next/
/mindquarry/out/

# production
/mindquarry/build

# misc
.mindquarry/.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

